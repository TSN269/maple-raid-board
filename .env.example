# Supabase Project Settings > API
# Vite only exposes variables prefixed with VITE_
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key


ARTALE_PRICE_DATA_URL=
# 若資料來源需要 Bearer / Token，可填完整 Authorization header，例如 Bearer xxx
ARTALE_PRICE_DATA_AUTH_HEADER=
# 前端查詢端點，預設為 /.netlify/functions/artale-prices
VITE_ARTALE_PRICE_ENDPOINT=/.netlify/functions/artale-prices

# Artale 物價資料來源：站長提供 Excel / CSV 直接下載 URL
ARTALE_PRICE_EXCEL_URL=
ARTALE_PRICE_EXCEL_SHEET=prices
ARTALE_PRICE_CSV_URL=
# 若資料來源需要 Bearer / Token，可填完整 Authorization header，例如 Bearer xxx
ARTALE_PRICE_DATA_AUTH_HEADER=
# Vercel 預設使用 /api/artale-prices；Netlify 可改為 /.netlify/functions/artale-prices
VITE_ARTALE_PRICE_ENDPOINT=/api/artale-prices

# 如果使用 Google Sheet 一般分享連結，可指定 gid；發布 CSV 連結通常不用填
ARTALE_PRICE_GOOGLE_SHEET_GID=
